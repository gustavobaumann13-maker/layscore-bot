# LAY_SCORE BOT - Environment Variables
# Copy this file to .env and fill in your actual credentials
# .env is in .gitignore and will NOT be committed to GitHub

# Telegram API Credentials
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=29422958
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Session String
# This is a session token from Telethon StringSession
TELEGRAM_SESSION=your_session_string_here

# Google Service Account Credentials (JSON)
# Download from Google Cloud Console and paste the entire JSON here
# This MUST be the complete service account JSON as a single-line string
GOOGLE_CREDS={"type": "service_account", "project_id": "...", ...}
